{
    "$schema": "https://schema.freqtrade.io/schema.json",
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "max_open_trades": 5,
    "stake_currency": "USDT",
    "stake_amount": 200,
    "tradable_balance_ratio": 1,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "timeframe": "5m",
    "dry_run_wallet": 1000,
    "cancel_open_orders_on_exit": true,
    "unfilledtimeout": {
        "entry": 10,
        "exit": 30
    },
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT:USDT",
            "ETH/USDT:USDT",
            "ADA/USDT:USDT",
            "DOT/USDT:USDT",
            "LINK/USDT:USDT",
            "BNB/USDT:USDT"
        ],
        "pair_blacklist": []
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "other",
        "use_order_book": true,
        "order_book_top": 1
    },
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "freqai": {
        "enabled": true,
        "purge_old_models": 3,
        "train_period_days": 30,
        "backtest_period_days": 7,
        "live_retrain_hours": 4,
        "expiration_hours": 2,
        "identifier": "production-freqai-v1",
        "save_backtest_models": true,
        "fit_live_predictions_candles": 300,
        "continual_learning": false,
        "write_metrics_to_disk": true,
        "data_kitchen_thread_count": 4,
        "activate_tensorboard": true,
        "wait_for_training_iteration_on_reload": true,
        "feature_parameters": {
            "include_timeframes": [
                "5m",
                "15m",
                "1h",
                "4h"
            ],
            "include_corr_pairlist": [
                "BTC/USDT:USDT",
                "ETH/USDT:USDT",
                "BNB/USDT:USDT"
            ],
            "label_period_candles": 24,
            "include_shifted_candles": 3,
            "indicator_periods_candles": [10, 20, 50],
            "weight_factor": 0.9,
            "principal_component_analysis": false,
            "plot_feature_importances": 20,
            "DI_threshold": 0.9,
            "use_SVM_to_remove_outliers": true,
            "svm_params": {
                "nu": 0.1,
                "shuffle": false,
                "max_iter": 1000
            },
            "use_DBSCAN_to_remove_outliers": false,
            "noise_standard_deviation": 0.05,
            "outlier_protection_percentage": 30,
            "reverse_train_test_order": false,
            "shuffle_after_split": false,
            "buffer_train_data_candles": 0
        },
        "data_split_parameters": {
            "test_size": 0.25,
            "shuffle": false,
            "random_state": 42
        },
        "model_training_parameters": {
            "n_estimators": 100,
            "learning_rate": 0.1,
            "max_depth": 6,
            "subsample": 0.8,
            "colsample_bytree": 0.8,
            "reg_alpha": 0.1,
            "reg_lambda": 1.0,
            "random_state": 42,
            "n_jobs": -1,
            "verbose": -1
        }
    },
    "bot_name": "FreqAI Production Bot",
    "force_entry_enable": true,
    "initial_state": "running",
    "internals": {
        "process_throttle_secs": 5
    }
}
